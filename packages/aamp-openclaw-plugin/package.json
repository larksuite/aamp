{
  "name": "aamp-openclaw-plugin",
  "files": [
    "dist",
    "bin",
    "openclaw.plugin.json",
    "skills"
  ],
  "license": "MIT",
  "version": "0.1.43",
  "description": "AAMP Agent Mail Protocol — OpenClaw plugin. Gives OpenClaw an AAMP mailbox identity and lets it receive, process and reply to AAMP tasks.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aamp-openclaw-plugin": "./bin/aamp-openclaw-plugin.mjs"
  },
  "openclaw": {
    "id": "aamp-openclaw-plugin",
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "minHostVersion": ">=2026.3.22"
    },
    "contracts": {
      "tools": [
        "aamp_directory_search",
        "aamp_send_result",
        "aamp_send_help",
        "aamp_pending_tasks",
        "aamp_pairing_code",
        "aamp_cancel_task",
        "aamp_dispatch_task",
        "aamp_check_protocol",
        "aamp_download_attachment"
      ]
    },
    "channelConfigs": {
      "aamp": {
        "label": "AAMP",
        "description": "AAMP mailbox channel for receiving and replying to tasks over email.",
        "schema": {
          "type": "object",
          "properties": {
            "aampHost": {
              "type": "string",
              "description": "AAMP service host, e.g. https://meshmail.ai"
            },
            "taskDispatchConcurrency": {
              "type": "integer",
              "minimum": 1,
              "default": 10,
              "description": "Maximum number of inbound task.dispatch handlers running concurrently before OpenClaw enqueues them locally."
            },
            "slug": {
              "type": "string",
              "default": "openclaw-agent",
              "description": "Agent name prefix used in the mailbox address"
            },
            "summary": {
              "type": "string",
              "description": "Directory summary shown when other agents search for this agent"
            },
            "cardText": {
              "type": "string",
              "description": "Inline card text used for automatic card.response replies"
            },
            "cardFile": {
              "type": "string",
              "description": "Absolute path to a card text file used when cardText is not set"
            },
            "credentialsFile": {
              "type": "string",
              "default": "~/.openclaw/extensions/aamp-openclaw-plugin/.credentials.json",
              "description": "Path to persist AAMP credentials between restarts"
            },
            "pairingFile": {
              "type": "string",
              "default": "~/.openclaw/extensions/aamp-openclaw-plugin/.pairing.json",
              "description": "Path to persist the current one-time AAMP pairing code"
            },
            "senderPoliciesFile": {
              "type": "string",
              "default": "~/.openclaw/extensions/aamp-openclaw-plugin/.sender-policies.json",
              "description": "Path to persist senders approved by pair.request"
            },
            "senderPolicies": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "sender"
                ],
                "properties": {
                  "sender": {
                    "type": "string"
                  },
                  "dispatchContextRules": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "description": "Per-sender authorization policies. Each sender can optionally require exact-match X-AAMP-Dispatch-Context key/value pairs."
            }
          }
        },
        "uiHints": {
          "aampHost": {
            "label": "AAMP Host",
            "placeholder": "https://meshmail.ai",
            "promptOnInstall": true
          },
          "taskDispatchConcurrency": {
            "label": "Task Concurrency",
            "placeholder": "10",
            "promptOnInstall": false
          },
          "slug": {
            "label": "Agent Slug",
            "placeholder": "openclaw-agent",
            "promptOnInstall": false
          },
          "summary": {
            "label": "Directory Summary",
            "placeholder": "Code review, debugging, and incident summaries",
            "promptOnInstall": false
          },
          "cardText": {
            "label": "Card Text",
            "placeholder": "Detailed capability card text",
            "promptOnInstall": false
          },
          "cardFile": {
            "label": "Card File",
            "placeholder": "/absolute/path/to/card.md",
            "promptOnInstall": false
          },
          "credentialsFile": {
            "label": "Credentials File",
            "placeholder": "~/.openclaw/extensions/aamp-openclaw-plugin/.credentials.json",
            "promptOnInstall": false
          },
          "pairingFile": {
            "label": "Pairing File",
            "placeholder": "~/.openclaw/extensions/aamp-openclaw-plugin/.pairing.json",
            "promptOnInstall": false
          },
          "senderPoliciesFile": {
            "label": "Paired Senders File",
            "placeholder": "~/.openclaw/extensions/aamp-openclaw-plugin/.sender-policies.json",
            "promptOnInstall": false
          },
          "senderPolicies": {
            "label": "Sender Policies",
            "placeholder": "[{\"sender\":\"meegle-bot@meshmail.ai\",\"dispatchContextRules\":{\"project_key\":[\"proj_123\"]}}]",
            "promptOnInstall": true
          }
        }
      }
    },
    "configSchema": {
      "type": "object",
      "properties": {
        "aampHost": {
          "type": "string",
          "description": "AAMP service host, e.g. https://meshmail.ai"
        },
        "taskDispatchConcurrency": {
          "type": "integer",
          "minimum": 1,
          "default": 10,
          "description": "Maximum number of inbound task.dispatch handlers running concurrently before OpenClaw enqueues them locally."
        },
        "slug": {
          "type": "string",
          "default": "openclaw-agent",
          "description": "Agent name prefix used in the mailbox address"
        },
        "summary": {
          "type": "string",
          "description": "Directory summary shown when other agents search for this agent"
        },
        "cardText": {
          "type": "string",
          "description": "Inline card text used for automatic card.response replies"
        },
        "cardFile": {
          "type": "string",
          "description": "Absolute path to a card text file used when cardText is not set"
        },
        "credentialsFile": {
          "type": "string",
          "default": "~/.openclaw/extensions/aamp-openclaw-plugin/.credentials.json",
          "description": "Path to persist AAMP credentials between restarts"
        },
        "pairingFile": {
          "type": "string",
          "default": "~/.openclaw/extensions/aamp-openclaw-plugin/.pairing.json",
          "description": "Path to persist the current one-time AAMP pairing code"
        },
        "senderPoliciesFile": {
          "type": "string",
          "default": "~/.openclaw/extensions/aamp-openclaw-plugin/.sender-policies.json",
          "description": "Path to persist senders approved by pair.request"
        },
        "senderPolicies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "sender"
            ],
            "properties": {
              "sender": {
                "type": "string"
              },
              "dispatchContextRules": {
                "type": "object",
                "additionalProperties": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "description": "Per-sender authorization policies. Each sender can optionally require exact-match X-AAMP-Dispatch-Context key/value pairs."
        }
      }
    },
    "uiHints": {
      "aampHost": {
        "label": "AAMP Host",
        "placeholder": "https://meshmail.ai",
        "promptOnInstall": true
      },
      "taskDispatchConcurrency": {
        "label": "Task Concurrency",
        "placeholder": "10",
        "promptOnInstall": false
      },
      "slug": {
        "label": "Agent Slug",
        "placeholder": "openclaw-agent",
        "promptOnInstall": false
      },
      "summary": {
        "label": "Directory Summary",
        "placeholder": "Code review, debugging, and incident summaries",
        "promptOnInstall": false
      },
      "cardText": {
        "label": "Card Text",
        "placeholder": "Detailed capability card text",
        "promptOnInstall": false
      },
      "cardFile": {
        "label": "Card File",
        "placeholder": "/absolute/path/to/card.md",
        "promptOnInstall": false
      },
      "credentialsFile": {
        "label": "Credentials File",
        "placeholder": "~/.openclaw/extensions/aamp-openclaw-plugin/.credentials.json",
        "promptOnInstall": false
      },
      "pairingFile": {
        "label": "Pairing File",
        "placeholder": "~/.openclaw/extensions/aamp-openclaw-plugin/.pairing.json",
        "promptOnInstall": false
      },
      "senderPoliciesFile": {
        "label": "Paired Senders File",
        "placeholder": "~/.openclaw/extensions/aamp-openclaw-plugin/.sender-policies.json",
        "promptOnInstall": false
      },
      "senderPolicies": {
        "label": "Sender Policies",
        "placeholder": "[{\"sender\":\"meegle-bot@meshmail.ai\",\"dispatchContextRules\":{\"project_key\":[\"proj_123\"]}}]",
        "promptOnInstall": true
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js --watch",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "aamp-sdk": "file:../sdks/nodejs",
    "nodemailer": "^6.9.10",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/qrcode-terminal": "^0.12.2",
    "esbuild": "^0.20.2",
    "typescript": "^5.4.3",
    "vitest": "^1.6.1"
  }
}
