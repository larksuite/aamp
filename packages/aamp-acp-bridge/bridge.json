        "system@aamp.local"
      ]
    },
    {
      "name": "openclaw",
      "acpCommand": "openclaw",
      "slug": "openclaw-bridge",
      "credentialsFile": "~/.acp-bridge/.aamp-openclaw.json",
      "description": "openclaw via ACP bridge"
    }
  ]
}
